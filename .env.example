APP_NAME=Liberaspace
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# --- DATABASE ---
# Local dev: DB_CONNECTION=sqlite （database/database.sqlite が自動生成）
# Railway:   add a "PostgreSQL" plugin → Railway が以下を inject
#   DATABASE_URL=postgresql://... を使うか、DB_* に個別代入
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=r2
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Cloudflare R2 (S3互換) ---
# 画像・PDF はここに置く（Railway は ephemeral FS のため）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=liberaspace-media
AWS_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
AWS_URL=https://media.example.com
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

# 公開サイトの GA4 計測 ID。空欄にすると gtag は出力されない。
GA_MEASUREMENT_ID=
